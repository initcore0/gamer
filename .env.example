# ─────────────────────────────────────────────────────────────────────────────
# gamer — example configuration.
#
# Copy to `.env` and fill in real values. `.env` is gitignored and MUST NEVER be
# committed. Every value here is FAKE. See SECURITY.md for how to obtain and
# rotate each credential.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
GAMER_ENV=dev                       # dev | prod
GAMER_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
GAMER_LOG_JSON=false                # true => structured JSON logs (prod)

# ── Database ─────────────────────────────────────────────────────────────────
# Local Postgres 16 + pgvector (see docker-compose.yml). Password is local-only.
GAMER_DB__HOST=localhost
GAMER_DB__PORT=5432
GAMER_DB__USER=gamer
GAMER_DB__PASSWORD=change-me-local-only
GAMER_DB__NAME=gamer

# ── Steam ────────────────────────────────────────────────────────────────────
# Free key: https://steamcommunity.com/dev/apikey  (rotation: SECURITY.md)
GAMER_STEAM__API_KEY=0000000000000000FAKEFAKEFAKE0000

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather. Token format: 123456:ABC-DEF...
GAMER_TELEGRAM__BOT_TOKEN=123456789:AAFAKEFAKEFAKEFAKEFAKEFAKEFAKEFAKE
GAMER_TELEGRAM__DM_CHAT_ID=0        # streamer's private chat id (interactive)
GAMER_TELEGRAM__GROUP_CHAT_ID=0     # broadcast group chat id (read-only digest)

# ── Twitch (optional, M4) ────────────────────────────────────────────────────
# https://dev.twitch.tv/console/apps  — free tier.
GAMER_TWITCH__CLIENT_ID=
GAMER_TWITCH__CLIENT_SECRET=

# ── Local models (optional) ──────────────────────────────────────────────────
GAMER_EMBEDDINGS__ENABLED=false
GAMER_EMBEDDINGS__MODEL=BAAI/bge-small-en-v1.5
GAMER_LLM__ENABLED=false            # feature-flag: digest summaries
GAMER_LLM__API=ollama               # ollama | openai (OpenAI-compatible server)
GAMER_LLM__MODEL=llama3.1:8b
# api=ollama → native Ollama endpoint:
GAMER_LLM__OLLAMA_URL=http://localhost:11434
# api=openai → OpenAI-compatible server (llama.cpp/vLLM/LM Studio); include /v1:
GAMER_LLM__OPENAI_BASE_URL=http://localhost:8080/v1
GAMER_LLM__OPENAI_API_KEY=          # usually blank for a local llama.cpp server

# ── Broader news (RSS) ───────────────────────────────────────────────────────
GAMER_RSS__ENABLED=true
# Comma-separated feed URLs (defaults to PC Gamer, RPS, Eurogamer).
GAMER_RSS__FEEDS=https://www.pcgamer.com/rss/,https://www.rockpapershotgun.com/feed,https://www.eurogamer.net/feed

# ── Health / status (M4) ─────────────────────────────────────────────────────
GAMER_HEALTH__STALE_AFTER_HOURS=24  # a source silent longer than this alerts you
GAMER_HEALTH__API_HOST=0.0.0.0
GAMER_HEALTH__API_PORT=8080

# ── Discord (M5, optional) ───────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
GAMER_DISCORD__WEBHOOK_URL=

# ── Switch eShop (M5, optional) ──────────────────────────────────────────────
GAMER_SWITCH__ENABLED=false
GAMER_SWITCH__FEED_URL=
